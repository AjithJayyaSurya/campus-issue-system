{
  "client": "Thunder Client",
  "collectionName": "Campus Issue System API",
  "dateExport": "2026-04-24",
  "version": "1.1",
  "folders": [
    {
      "name": "AUTH",
      "requests": [
        {
          "name": "🚀 1. Register User",
          "method": "POST",
          "url": "http://localhost:8080/api/auth/register",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"name\": \"Ajith\",\n  \"email\": \"ajith@test.com\",\n  \"password\": \"123456\"\n}"
          }
        },
        {
          "name": "🔐 2. Login User",
          "method": "POST",
          "url": "http://localhost:8080/api/auth/login",
          "headers": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"email\": \"ajith@test.com\",\n  \"password\": \"123456\"\n}"
          }
        }
      ]
    },
    {
      "name": "ISSUES",
      "requests": [
        {
          "name": "📝 3. Create Issue (WITH IMAGE)",
          "method": "POST",
          "url": "http://localhost:8080/api/issues",
          "headers": [
            {
              "key": "Authorization",
              "value": "Bearer YOUR_TOKEN_HERE"
            }
          ],
          "body": {
            "type": "formdata",
            "formdata": [
              {
                "key": "title",
                "value": "Broken Fan",
                "type": "text"
              },
              {
                "key": "description",
                "value": "Fan not working in room 101",
                "type": "text"
              },
              {
                "key": "category",
                "value": "infrastructure",
                "type": "text"
              },
              {
                "key": "image",
                "value": "",
                "type": "file"
              }
            ]
          }
        },
        {
          "name": "📋 Get All Issues (Admin/Staff)",
          "method": "GET",
          "url": "http://localhost:8080/api/issues",
          "headers": [
            {
              "key": "Authorization",
              "value": "Bearer ADMIN_TOKEN_HERE"
            }
          ]
        },
        {
          "name": "👤 Get My Issues (Student)",
          "method": "GET",
          "url": "http://localhost:8080/api/issues/my",
          "headers": [
            {
              "key": "Authorization",
              "value": "Bearer YOUR_TOKEN_HERE"
            }
          ]
        },
        {
          "name": "🎯 Update Issue Status (Staff)",
          "method": "PUT",
          "url": "http://localhost:8080/api/issues/ISSUE_ID/status",
          "headers": [
            {
              "key": "Authorization",
              "value": "Bearer STAFF_TOKEN_HERE"
            },
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"status\": \"in-progress\"\n}"
          }
        }
      ]
    },
    {
      "name": "COMMENTS",
      "requests": [
        {
          "name": "💬 4. Add Comment",
          "method": "POST",
          "url": "http://localhost:8080/api/comments",
          "headers": [
            {
              "key": "Authorization",
              "value": "Bearer YOUR_TOKEN_HERE"
            },
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"issueId\": \"ISSUE_ID_HERE\",\n  \"message\": \"We are working on this issue\"\n}"
          }
        },
        {
          "name": "📖 Get Comments by Issue",
          "method": "GET",
          "url": "http://localhost:8080/api/comments/ISSUE_ID",
          "headers": [
            {
              "key": "Authorization",
              "value": "Bearer YOUR_TOKEN_HERE"
            }
          ]
        }
      ]
    },
    {
      "name": "ADMIN",
      "requests": [
        {
          "name": "🧑‍💼 5. Assign Issue to Staff",
          "method": "POST",
          "url": "http://localhost:8080/api/admin/assign",
          "headers": [
            {
              "key": "Authorization",
              "value": "Bearer ADMIN_TOKEN_HERE"
            },
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"issueId\": \"ISSUE_ID_HERE\",\n  \"staffId\": \"STAFF_USER_ID_HERE\"\n}"
          }
        },
        {
          "name": "📋 Get Assigned Issues (Staff)",
          "method": "GET",
          "url": "http://localhost:8080/api/admin/assigned",
          "headers": [
            {
              "key": "Authorization",
              "value": "Bearer STAFF_TOKEN_HERE"
            }
          ]
        }
      ]
    },
    {
      "name": "LOGS",
      "requests": [
        {
          "name": "📜 Get Logs by Issue",
          "method": "GET",
          "url": "http://localhost:8080/api/logs/ISSUE_ID",
          "headers": [
            {
              "key": "Authorization",
              "value": "Bearer YOUR_TOKEN_HERE"
            }
          ]
        }
      ]
    },
    {
      "name": "ANALYTICS",
      "requests": [
        {
          "name": "📊 Get Analytics (Admin)",
          "method": "GET",
          "url": "http://localhost:8080/api/analytics",
          "headers": [
            {
              "key": "Authorization",
              "value": "Bearer ADMIN_TOKEN_HERE"
            }
          ]
        }
      ]
    },
    {
      "name": "TEST ROUTES",
      "requests": [
        {
          "name": "🔒 Protected Route",
          "method": "GET",
          "url": "http://localhost:8080/api/protected",
          "headers": [
            {
              "key": "Authorization",
              "value": "Bearer YOUR_TOKEN_HERE"
            }
          ]
        },
        {
          "name": "✅ Test Connection",
          "method": "GET",
          "url": "http://localhost:8080/",
          "headers": []
        }
      ]
    }
  ]
}
